```rust
pub struct SkyLightingPlugin;

impl Plugin for SkyLightingPlugin {
    fn build(&self, app: &mut App) {
        app
            .init_resource::<CelestialState>()
            .init_resource::<WeatherLightingState>()
            .add_systems(
                Update,
                (
                    update_celestial_state,
                    update_sun_light,
                    update_moon_light,
                    update_environment_lighting,
                    update_fog,
                    update_exposure,
                    update_shared_sky_uniform,
                )
                    .chain(),
            );
    }
}
```

Separate simulation updates from visual interpolation:

```text
Simulation:
updates weather and celestial targets

Rendering:
smoothly interpolates light and fog values
```

